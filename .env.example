# ===========================================================
# 5S ProAudit — Environment Variables
# ===========================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ===========================================================
# SUPABASE (Required)
# ===========================================================
# Get these from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (NEVER expose to browser - server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================================
# APP SETTINGS
# ===========================================================
NEXT_PUBLIC_APP_URL=https://your-domain.netlify.app
NEXT_PUBLIC_APP_NAME="5S ProAudit"
NEXT_PUBLIC_COMPANY_NAME="5S ProAudit Corp"
NEXT_PUBLIC_ENABLE_DEMO=true

# ===========================================================
# AI (Optional - for AI features)
# ===========================================================
# Uncomment and fill if using AI recommendations
# GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key

# ===========================================================
# EMAIL (Optional - for email notifications via Supabase)
# ===========================================================
# Configure in Supabase Dashboard → Authentication → Email Templates

# ===========================================================
# SETUP INSTRUCTIONS
# ===========================================================
# 1. Create a Supabase project at https://supabase.com
# 2. Copy your Project URL and Anon Key from Settings → API
# 3. Run the SQL schema from supabase/schema.sql in SQL Editor
# 4. Set up Storage buckets: 'audit-attachments', 'avatars', 'company-logos'
# 5. Create a demo user in Supabase Auth dashboard:
#    Email: demo@5sproaudit.com | Password: Demo@12345
# 6. Update the demo user's profile in the profiles table:
#    role: 'corporate_admin'
#    company_id: '11111111-1111-1111-1111-111111111111'
#    full_name: 'Demo Admin'
# 7. Deploy to Netlify with these env vars set in the dashboard
